generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      String   @default("USER")
  status    String   @default("ativo")
  createdAt DateTime @default(now())
}

model PromptSetting {
  id          String   @id @default(cuid())
  toneKey     String   @unique // e.g., 'PROVOCATIVO', 'ANALITICO'
  label       String   // e.g., 'Provocativo (O Soco no Estômago)'
  instruction String   @db.Text
  updatedAt   DateTime @updatedAt
}

model ImagePromptSetting {
  id          String   @id @default(cuid())
  nicheKey    String   @unique // e.g., 'GLOBAL_IMAGE', 'SAUDE'
  label       String   // e.g., 'Instruções Gerais (Imagens)', 'Saúde'
  instruction String   @db.Text
  isDeletable Boolean  @default(true) // Impede deleção da instrução global
  updatedAt   DateTime @updatedAt
}
